# Copy these keys into Streamlit Community Cloud > App > Settings > Secrets
ORS_API_KEY = "your-openrouteservice-key"
CARBON_LOG_LEVEL = "INFO"
CARBON_DB_BACKEND = "postgres"
SUPABASE_DB_HOST = "db.your-project-ref.supabase.co"
SUPABASE_DB_PORT = 5432
SUPABASE_DB_NAME = "postgres"
SUPABASE_DB_USER = "postgres"
SUPABASE_DB_PASSWORD = "your-supabase-password"
SUPABASE_DB_SSLMODE = "require"
CARBON_WRITE_LOG_FILE = false
# Optional legacy SQLite fallback only
CARBON_DB_PATH = "/tmp/carbon-footprint/carbon_footprint.sqlite"
